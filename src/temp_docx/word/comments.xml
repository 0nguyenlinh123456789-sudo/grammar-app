<w:comments xmlns:wpc="http://schemas.microsoft.com/office/word/2010/wordprocessingCanvas" xmlns:cx="http://schemas.microsoft.com/office/drawing/2014/chartex" xmlns:cx1="http://schemas.microsoft.com/office/drawing/2015/9/8/chartex" xmlns:cx2="http://schemas.microsoft.com/office/drawing/2015/10/21/chartex" xmlns:cx3="http://schemas.microsoft.com/office/drawing/2016/5/9/chartex" xmlns:cx4="http://schemas.microsoft.com/office/drawing/2016/5/10/chartex" xmlns:cx5="http://schemas.microsoft.com/office/drawing/2016/5/11/chartex" xmlns:cx6="http://schemas.microsoft.com/office/drawing/2016/5/12/chartex" xmlns:cx7="http://schemas.microsoft.com/office/drawing/2016/5/13/chartex" xmlns:cx8="http://schemas.microsoft.com/office/drawing/2016/5/14/chartex" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:aink="http://schemas.microsoft.com/office/drawing/2016/ink" xmlns:am3d="http://schemas.microsoft.com/office/drawing/2017/model3d" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships" xmlns:m="http://schemas.openxmlformats.org/officeDocument/2006/math" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:wp14="http://schemas.microsoft.com/office/word/2010/wordprocessingDrawing" xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing" xmlns:w10="urn:schemas-microsoft-com:office:word" xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main" xmlns:w14="http://schemas.microsoft.com/office/word/2010/wordml" xmlns:w15="http://schemas.microsoft.com/office/word/2012/wordml" xmlns:w16cex="http://schemas.microsoft.com/office/word/2018/wordml/cex" xmlns:w16cid="http://schemas.microsoft.com/office/word/2016/wordml/cid" xmlns:w16="http://schemas.microsoft.com/office/word/2018/wordml" xmlns:w16sdtdh="http://schemas.microsoft.com/office/word/2020/wordml/sdtdatahash" xmlns:w16se="http://schemas.microsoft.com/office/word/2015/wordml/symex" xmlns:wpg="http://schemas.microsoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" mc:Ignorable="w14 w15 w16se w16cid w16 w16cex w16sdtdh wp14"><w:comment w:id="271" w:author="Vũ Thị Hạnh Tâm" w:date="2025-08-05T08:40:00Z" w:initials="VTHT"><w:p w14:paraId="42425875" w14:textId="6020431E" w:rsidR="00FA1921" w:rsidRPr="00FA1921" w:rsidRDefault="009C6017" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/><w:rPr><w:b/><w:bCs/><w:color w:val="FF0000"/></w:rPr></w:pPr><w:r><w:rPr><w:rStyle w:val="CommentReference"/></w:rPr><w:annotationRef/></w:r><w:r w:rsidR="00FA1921" w:rsidRPr="00FA1921"><w:rPr><w:b/><w:bCs/><w:color w:val="FF0000"/></w:rPr><w:t>Viết lại nội dung này theo hướng dãn dưới của cô cho cụ thể hoá nội dung giải pháp</w:t></w:r><w:r w:rsidR="00FA1921"><w:rPr><w:b/><w:bCs/><w:color w:val="FF0000"/></w:rPr><w:t xml:space="preserve"> (TUY nhiên trình bày lại chứ không phải gạch đầu dòng như gợi ý cũa cô nhé)</w:t></w:r></w:p><w:p w14:paraId="7DF56D7C" w14:textId="5A9FDF32" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>Giải pháp 2: Cải thiện quy trình tư vấn mở tài khoản và nâng cao trải nghiệm khách hàng cá nhân</w:t></w:r></w:p><w:p w14:paraId="4B763105" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>4.2.1. Nội dung giải pháp</w:t></w:r></w:p><w:p w14:paraId="10437A24" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>Hiện tại, quy trình tư vấn và mở tài khoản tại PGD Quyết Thắng – HDBank còn tồn tại nhiều điểm chưa phù hợp với yêu cầu hiện đại hóa dịch vụ. Các bước thủ tục còn rườm rà, sử dụng nhiều biểu mẫu giấy, gây mất thời gian cho cả khách hàng lẫn nhân viên. Ngoài ra, việc tiếp cận khách hàng mới vẫn còn phụ thuộc chủ yếu vào sự chủ động cá nhân của từng nhân viên, thiếu sự hỗ trợ từ các công cụ tiếp cận khách hàng hiện đại và chưa có kịch bản tư vấn thống nhất.</w:t></w:r></w:p><w:p w14:paraId="07B16B15" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr></w:p><w:p w14:paraId="3C65BA5A" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>Do đó, giải pháp được đề xuất tập trung vào 3 hướng cụ thể:</w:t></w:r></w:p><w:p w14:paraId="25AAF19A" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr></w:p><w:p w14:paraId="2A0371CB" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>1. Tái cấu trúc quy trình mở tài khoản theo hướng số hóa và tối giản</w:t></w:r></w:p><w:p w14:paraId="61315235" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>Xây dựng quy trình 5 bước chuẩn, áp dụng thống nhất tại PGD:</w:t></w:r></w:p><w:p w14:paraId="3C2BB6D0" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr></w:p><w:p w14:paraId="74111131" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>Tiếp nhận nhu cầu khách hàng</w:t></w:r></w:p><w:p w14:paraId="4DCD7784" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr></w:p><w:p w14:paraId="5E6EE063" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>Hướng dẫn đăng ký trên thiết bị điện tử (máy tính bảng tại quầy hoặc đăng ký online từ xa)</w:t></w:r></w:p><w:p w14:paraId="5EA32335" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr></w:p><w:p w14:paraId="338AA203" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>Xác minh thông tin và định danh điện tử (eKYC)</w:t></w:r></w:p><w:p w14:paraId="68762D4C" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr></w:p><w:p w14:paraId="18B49F25" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>Hoàn tất thủ tục, cấp số tài khoản và phát hành thẻ (nếu có)</w:t></w:r></w:p><w:p w14:paraId="6449FC72" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr></w:p><w:p w14:paraId="05668F7D" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>Giới thiệu các dịch vụ đi kèm (mobile banking, SMS banking, tiết kiệm online,…)</w:t></w:r></w:p><w:p w14:paraId="4A9B5B5E" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr></w:p><w:p w14:paraId="450CFE63" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>Ứng dụng công nghệ:</w:t></w:r></w:p><w:p w14:paraId="1E88029E" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr></w:p><w:p w14:paraId="62D93B64" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>Cung cấp biểu mẫu điện tử thay thế biểu mẫu giấy.</w:t></w:r></w:p><w:p w14:paraId="42C85CEB" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr></w:p><w:p w14:paraId="1BA18B4D" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>Tích hợp nền tảng đăng ký tài khoản trực tuyến (qua website/app) và đồng bộ hóa dữ liệu về hệ thống tại PGD.</w:t></w:r></w:p><w:p w14:paraId="1F69B9FA" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr></w:p><w:p w14:paraId="36107DB8" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>Triển khai hệ thống eKYC tại điểm giao dịch, giúp khách hàng chỉ cần mang CMND/CCCD là có thể mở tài khoản nhanh chóng.</w:t></w:r></w:p><w:p w14:paraId="31B3C3C7" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr></w:p><w:p w14:paraId="586A6B27" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>2. Chuẩn hóa nội dung và kịch bản tư vấn khách hàng</w:t></w:r></w:p><w:p w14:paraId="059DAA69" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>Xây dựng bộ tài liệu tư vấn mẫu gồm:</w:t></w:r></w:p><w:p w14:paraId="0C9F3F8F" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr></w:p><w:p w14:paraId="54561A61" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>Tài liệu hỏi đáp thường gặp (FAQ) khi mở tài khoản.</w:t></w:r></w:p><w:p w14:paraId="063ED562" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr></w:p><w:p w14:paraId="338CB16C" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>Tài liệu so sánh ưu điểm các loại tài khoản để nhân viên dễ trình bày.</w:t></w:r></w:p><w:p w14:paraId="377F4524" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr></w:p><w:p w14:paraId="288C45CE" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>Mẫu kịch bản tư vấn 1:1 áp dụng cho khách hàng mới đến lần đầu, kèm các gợi ý chốt sale (up-selling, cross-selling).</w:t></w:r></w:p><w:p w14:paraId="285EAD81" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr></w:p><w:p w14:paraId="5332F425" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>Tổ chức chương trình “1 ngày trải nghiệm khách hàng”: Tất cả nhân viên tư vấn sẽ luân phiên đóng vai khách hàng để hiểu cảm giác và khó khăn trong từng khâu quy trình.</w:t></w:r></w:p><w:p w14:paraId="64CD17D1" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr></w:p><w:p w14:paraId="2B1787BE" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>3. Mở rộng kênh tư vấn và hỗ trợ từ xa</w:t></w:r></w:p><w:p w14:paraId="40BF3D32" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>Triển khai các kênh tư vấn mở tài khoản từ xa, gồm:</w:t></w:r></w:p><w:p w14:paraId="039B7159" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr></w:p><w:p w14:paraId="7D581010" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>Chat tư vấn trực tuyến trên website và app.</w:t></w:r></w:p><w:p w14:paraId="366D2083" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr></w:p><w:p w14:paraId="13850E3F" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>Tổng đài hỗ trợ có chuyên viên tư vấn mở tài khoản chuyên biệt.</w:t></w:r></w:p><w:p w14:paraId="72803364" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr></w:p><w:p w14:paraId="3B407F7C" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>Đăng ký mở tài khoản qua Zalo Official Account hoặc các nền tảng mạng xã hội của ngân hàng.</w:t></w:r></w:p><w:p w14:paraId="34679123" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr></w:p><w:p w14:paraId="0437C46F" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="00FA1921" w:rsidP="00FA1921"><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:r><w:t>Cập nhật video hướng dẫn quy trình mở tài khoản, đăng tải công khai trên nền tảng online (YouTube, Website, Fanpage HDBank).</w:t></w:r></w:p><w:p w14:paraId="6A778C32" w14:textId="77777777" w:rsidR="00FA1921" w:rsidRDefault="